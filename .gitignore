# ============================================
# Obra 10 — Monorepo .gitignore
# ============================================

# Dependencies
node_modules/

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment variables (secrets)
.env
.env.*
.env.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS generated files
.DS_Store
Thumbs.db
*.tmp
*.bak

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Prisma generated client
obra10-backend/generated/

# Uploads (user-generated content)
# obra10-backend/uploads/

# SQLite databases (if any)
*.db
*.sqlite

# Antigravity / AI agent working files
.gemini/

# Temporary tunnel/test scripts (root level)
pinggy.cjs
serveo.cjs
tunnel.cjs
tunnel_out.txt
test-login.js
secops_tester.js

# Root-level package (only localtunnel dep, not project code)
/package.json
/package-lock.json

# AI agent generated intermediary files
*.metadata.json
*.resolved
*.resolved.*

# Playwright test artifacts
obra10-frontend/playwright-report/
obra10-frontend/test-results/
obra10-frontend/tests/.auth/

# Debug output files
obra10-backend/out*.txt
obra10-backend/out*.json
obra10-backend/cpf_err.txt
obra10-backend/users_out.txt
obra10-backend/ts_errors.txt
obra10-backend/tsc_errors.txt
obra10-backend/tsc_out.txt
obra10-backend/error.log

# One-off debug/migration scripts (keep in local only)
obra10-backend/check*.js
obra10-backend/fix-*.cjs
obra10-backend/list_*.js
obra10-backend/migrate_*.js
obra10-backend/reset_*.js
obra10-backend/scripts/check*.ts
obra10-backend/scripts/dbcheck*.js
obra10-backend/scripts/reset_*.js
obra10-frontend/convert.js
